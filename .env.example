# =========================================================================
# Azure OpenAI — Chat Completions
# =========================================================================
AZURE_OPENAI_ENDPOINT=https://itiworkshop2026aifoundry.services.ai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-06-01

# =========================================================================
# Azure OpenAI — Embeddings
# =========================================================================
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://itiworkshop2026aifoundry.services.ai.azure.com
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_KEY=your-key-here

# =========================================================================
# Web Search
# =========================================================================
TAVILY_API_KEY=tvly-...

# =========================================================================
# Jira
# =========================================================================
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=...
JIRA_PROJECT_KEY=MEET

# =========================================================================
# Notion
# =========================================================================
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=...

# =========================================================================
# Microsoft Graph (Teams + Email)
# =========================================================================
MS_GRAPH_CLIENT_ID=...
MS_GRAPH_CLIENT_SECRET=...
MS_GRAPH_TENANT_ID=...

# =========================================================================
# Storage
# =========================================================================
chromadb_path=./chroma_db
REDIS_URL=redis://redis:6379/0

# =========================================================================
# LangSmith Observability
# =========================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=ai-meeting-system

# =========================================================================
# Email — SMTP fallback (used when MS Graph is not configured)
# =========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# =========================================================================
# Application
# =========================================================================
APP_HOST=0.0.0.0
APP_PORT=8080
HITL_TIMEOUT_SECONDS=600
