# ── Groq API (free tier — console.groq.com) ──────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Bot Settings ─────────────────────────────────────────────────
BOT_DISPLAY_NAME=Meeting Recorder
OUTPUT_DIR=./output

# ── App Server (optional — forward captions in real time) ────────
# URL of the FastAPI app server to receive live caption chunks
# APP_SERVER_URL=http://localhost:8080

# ── Caption Settings ─────────────────────────────────────────────
# Language for Teams captions (default: en)
# CAPTION_LANGUAGE=en
